# Reto rápido: Calculadora de edad
print("--- Micro Sistema de Registro ---")
nombre = input("¿Cómo te llamas? ")
año_nacimiento = input("¿En qué año naciste? ")

# Nota: input() siempre devuelve texto, hay que convertirlo a número (int)
edad = 2026 - int(año_nacimiento)

print(f"Hola {nombre}, según mis cálculos, tienes o cumplirás {edad} años.")
